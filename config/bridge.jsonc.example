{
  // required: matrix homeserver and bot identity
  // all fields can be overridden via BRIDGE_* env vars (e.g. BRIDGE_HOMESERVER)
  "homeserver": "https://matrix.example.org",
  "user_id": "@bridge-bot:example.org",
  "access_token": "syt_...",  // or set BRIDGE_ACCESS_TOKEN env var

  // room filtering (empty allowlist = all joined rooms)
  "room_allowlist": [],
  "room_blocklist": [],

  // trigger mode: "mention" (respond when @mentioned) or "all" (respond to every message)
  "default_trigger": "mention",
  // per-room overrides keyed by room ID
  "room_triggers": {},

  // display options for matrix output
  "display_tool_calls": false,
  "display_reasoning": false,
  "max_response_length": 4000,

  // model to use (optional — auto-detected from opencode if omitted)
  // accepts "provider/model" string or { "providerID": "...", "modelID": "..." }
  // "model": "anthropic/claude-sonnet-4-5",

  // custom system prompt instructions for group rooms (appended after room context)
  // set to "" to disable. default includes NO_RESPONSE opt-out and formatting guidance.
  // "system_prompt": "messages from different users are prefixed with [username].\nif a message is not directed at you or does not warrant a response,\nreply with exactly: [NO_RESPONSE]\nkeep responses short and concise.\nprefer plain text or minimal formatting, as not all matrix clients render markdown.",

  // opencode agent to use for prompts
  "agent": "per",

  // matrix sync settings
  "sync_timeout_ms": 30000,

  // path for matrix sync state persistence (relative to workspace)
  "storage_path": "state/",

  // context cleanup: "none" | "compact" | "new" | "archive"
  "cleanup": "none",
  // trigger cleanup when total tokens exceed this threshold
  "cleanup_tokens": null,
  // trigger cleanup when message count exceeds this threshold
  "cleanup_message_count": null
}
